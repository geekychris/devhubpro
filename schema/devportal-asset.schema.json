{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devportal.io/schema/asset/v1.json",
  "title": "DevPortal Asset Manifest",
  "description": "Manifest carried at the root of each managed repo as devportal.yaml.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "devportal.io/v1" },
    "kind": { "const": "Asset" },
    "metadata": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$",
          "description": "Globally unique slug, lowercase, kebab-case."
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["library", "service", "meta-asset"]
        },
        "language": {
          "type": "string",
          "examples": ["java", "typescript", "go", "python", "shell"]
        },
        "build": {
          "type": "object",
          "properties": {
            "tool": {
              "enum": ["maven", "gradle", "npm", "pnpm", "yarn", "cargo", "make", "shell", "none"]
            },
            "commands": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "Named commands. Conventional keys: install, test, build, package, clean."
            }
          },
          "additionalProperties": false
        },
        "docker": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "dockerfile": { "type": "string" },
            "context": { "type": "string" },
            "image": { "type": "string" },
            "images": {
              "type": "array",
              "description": "Multi-image build matrix. Each entry is built via 'docker build -t <tag> -f <dockerfile> <context>' relative to the asset workspace root. Use this for repos that produce multiple local images consumed by k8s manifests with imagePullPolicy: Never.",
              "items": {
                "type": "object",
                "required": ["tag"],
                "properties": {
                  "tag": { "type": "string", "description": "Image tag, e.g. worksphere/social-app:latest" },
                  "dockerfile": { "type": "string", "description": "Repo-relative Dockerfile path. Defaults to <context>/Dockerfile." },
                  "context": { "type": "string", "description": "Repo-relative build context. Defaults to '.'." }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "kubernetes": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "manifestPath": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "properties": {
            "ports": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Slot name. Portal allocates a concrete port at deploy time."
                  },
                  "protocol": { "enum": ["tcp", "udp"], "default": "tcp" },
                  "purpose": {
                    "type": "string",
                    "examples": ["http", "metrics", "debug", "grpc"]
                  }
                },
                "additionalProperties": false
              }
            },
            "env": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "default": { "type": "string" },
                  "description": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "versionRef": {
                "type": "string",
                "description": "Git ref (branch, tag, or SHA) to pin against. Defaults to main."
              }
            },
            "additionalProperties": false
          }
        },
        "consumes": {
          "type": "array",
          "description": "Meta-assets (shared infra) this asset needs at runtime.",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "examples": ["primary-db", "cache", "search"] }
            },
            "additionalProperties": false
          }
        },
        "docs": {
          "type": "object",
          "properties": {
            "architecture": { "type": "string" },
            "build": { "type": "string" },
            "run": { "type": "string" },
            "deploy": { "type": "string" },
            "runbook": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
